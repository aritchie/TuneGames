<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TuneGames"
             xmlns:m="clr-namespace:TuneGames.Models"
             x:Class="TuneGames.CategorySelectPage"
             x:DataType="vm:CategorySelectViewModel"
             Title="Choose Category"
             Padding="20">

    <Grid>

        <CollectionView ItemsSource="{Binding Groups}"
                        IsGrouped="True"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedCategory}"
                        SelectionChangedCommand="{Binding CategorySelectedCommand}">

            <CollectionView.Header>
                <Label Text="Pick a category for this round"
                       FontSize="18"
                       Opacity="0.7"
                       Margin="0,10,0,4" />
            </CollectionView.Header>

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:CategoryGroup">
                    <Label Text="{Binding Name}"
                           FontSize="22" FontAttributes="Bold"
                           Margin="0,16,0,4" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:CategoryItem">
                    <Border Margin="0,4" Padding="16"
                           StrokeShape="RoundRectangle 10"
                           Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                           BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#2A2A2A}">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding DisplayName}" FontSize="18" FontAttributes="Bold" />
                            <Label Grid.Column="1" FontSize="14" Opacity="0.6"
                                   VerticalOptions="Center">
                                <Label.Text>
                                    <Binding Path="TrackCount" StringFormat="{}{0} songs" />
                                </Label.Text>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Loading overlay -->
        <Grid IsVisible="{Binding IsLoading}"
              BackgroundColor="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   HeightRequest="48" WidthRequest="48"
                                   Color="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}" />
                <Label Text="Loading categories…"
                       FontSize="16"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
