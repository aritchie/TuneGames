<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TuneGames.Pages.CategorySelect"
             xmlns:m="clr-namespace:TuneGames.Models"
             x:Class="TuneGames.Pages.CategorySelect.CategorySelectPage"
             x:DataType="vm:CategorySelectViewModel"
             Title="Choose Category">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16">

            <Label Text="Pick a category for this round"
                   FontSize="18"
                   Opacity="0.7"
                   Margin="0,10,0,4" />

            <!-- Genres -->
            <Label Text="Genres"
                   FontSize="22" FontAttributes="Bold"
                   IsVisible="{Binding Genres.Count, Converter={StaticResource IntToBoolConverter}}" />
            <CollectionView ItemsSource="{Binding Genres}"
                            SelectionMode="None"
                            IsVisible="{Binding Genres.Count, Converter={StaticResource IntToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:CategoryItem">
                        <Frame Margin="0,4" Padding="16" CornerRadius="10"
                               BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                               BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#2A2A2A}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategorySelectViewModel}}, Path=SelectCategoryCommand}"
                                    CommandParameter="{Binding}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding DisplayName}" FontSize="18" FontAttributes="Bold" />
                                <Label Grid.Column="1" FontSize="14" Opacity="0.6"
                                       VerticalOptions="Center">
                                    <Label.Text>
                                        <Binding Path="TrackCount" StringFormat="{}{0} songs" />
                                    </Label.Text>
                                </Label>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Decades -->
            <Label Text="Decades"
                   FontSize="22" FontAttributes="Bold"
                   IsVisible="{Binding Decades.Count, Converter={StaticResource IntToBoolConverter}}" />
            <CollectionView ItemsSource="{Binding Decades}"
                            SelectionMode="None"
                            IsVisible="{Binding Decades.Count, Converter={StaticResource IntToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:CategoryItem">
                        <Frame Margin="0,4" Padding="16" CornerRadius="10"
                               BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                               BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#2A2A2A}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategorySelectViewModel}}, Path=SelectCategoryCommand}"
                                    CommandParameter="{Binding}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding DisplayName}" FontSize="18" FontAttributes="Bold" />
                                <Label Grid.Column="1" FontSize="14" Opacity="0.6"
                                       VerticalOptions="Center">
                                    <Label.Text>
                                        <Binding Path="TrackCount" StringFormat="{}{0} songs" />
                                    </Label.Text>
                                </Label>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Years -->
            <Label Text="Years"
                   FontSize="22" FontAttributes="Bold"
                   IsVisible="{Binding Years.Count, Converter={StaticResource IntToBoolConverter}}" />
            <CollectionView ItemsSource="{Binding Years}"
                            SelectionMode="None"
                            IsVisible="{Binding Years.Count, Converter={StaticResource IntToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:CategoryItem">
                        <Frame Margin="0,4" Padding="16" CornerRadius="10"
                               BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                               BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#2A2A2A}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategorySelectViewModel}}, Path=SelectCategoryCommand}"
                                    CommandParameter="{Binding}" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding DisplayName}" FontSize="18" FontAttributes="Bold" />
                                <Label Grid.Column="1" FontSize="14" Opacity="0.6"
                                       VerticalOptions="Center">
                                    <Label.Text>
                                        <Binding Path="TrackCount" StringFormat="{}{0} songs" />
                                    </Label.Text>
                                </Label>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
