<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TuneGames.Pages.GamePlay"
             x:Class="TuneGames.Pages.GamePlay.GamePlayPage"
             x:DataType="vm:GamePlayViewModel"
             Title="{Binding CategoryName}"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="*,Auto,*" Padding="30">

        <!-- Top: Status -->
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
            <Label Text="🎧"
                   FontSize="80"
                   HorizontalOptions="Center" />
            <Label Text="{Binding StatusText}"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="{Binding CurrentSongInfo}"
                   FontSize="16"
                   Opacity="0.7"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Middle: Progress -->
        <VerticalStackLayout Grid.Row="1" Spacing="8" Padding="20,0">
            <ProgressBar Progress="{Binding Progress}"
                         ProgressColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}"
                         HeightRequest="8" />
            <Label HorizontalOptions="Center"
                   Opacity="0.5">
                <Label.Text>
                    <MultiBinding StringFormat="Song {0} of {1}">
                        <Binding Path="CurrentSongNumber" />
                        <Binding Path="TotalSongs" />
                    </MultiBinding>
                </Label.Text>
            </Label>
        </VerticalStackLayout>

        <!-- Bottom: Hint -->
        <Label Grid.Row="2"
               Text="Listen carefully — you'll need to identify these songs!"
               FontSize="14"
               Opacity="0.4"
               HorizontalOptions="Center"
               VerticalOptions="End"
               Margin="0,0,0,30" />
    </Grid>

</ContentPage>
