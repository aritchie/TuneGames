<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TuneGames"
             x:Class="TuneGames.AnswerPage"
             x:DataType="vm:AnswerViewModel"
             Title="Name That Tune!"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">

        <!-- Timer Bar -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,10">
            <ProgressBar Progress="{Binding TimerProgress}"
                         ProgressColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}"
                         HeightRequest="8"
                         VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="{Binding TimerText}"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="10,0,0,0"
                   TextColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}" />
        </Grid>

        <!-- Song Choices -->
        <CollectionView Grid.Row="1"
                         ItemsSource="{Binding Choices}"
                         SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:AnswerChoice">
                    <Border Margin="0,4" Padding="14"
                            StrokeShape="RoundRectangle 10"
                            Stroke="{Binding IsSelected, Converter={StaticResource SelectedBorderColor}}"
                            BackgroundColor="{Binding IsSelected, Converter={StaticResource SelectedBackground}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AnswerViewModel}}, Path=ToggleChoiceCommand}"
                                CommandParameter="{Binding}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Text="{Binding IsSelected, Converter={StaticResource CheckMark}}"
                                   FontSize="20"
                                   VerticalOptions="Center"
                                   Margin="0,0,12,0" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding Song.Title}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label FontSize="13" Opacity="0.6">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} · {1}">
                                            <Binding Path="Song.Artist" />
                                            <Binding Path="Song.Album" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Submit -->
        <Button Grid.Row="2"
                Text="Submit Answers"
                Command="{Binding SubmitCommand}"
                IsEnabled="{Binding CanSubmit}"
                Margin="0,10,0,10"
                FontSize="18"
                HeightRequest="56"
                BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#7C4DFF}"
                TextColor="White"
                CornerRadius="12" />
    </Grid>

</ContentPage>
